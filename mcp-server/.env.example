# MCP Server Configuration
MCP_PORT=3001
MCP_HOST=localhost
MCP_LOG_LEVEL=info

# JIRA Cloud Configuration
# Get your API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_CLOUD_URL=https://your-domain.atlassian.net
JIRA_CLOUD_EMAIL=your-email@example.com
JIRA_CLOUD_API_TOKEN=your-api-token-here

# JIRA Data Center Configuration (Optional)
JIRA_DC_URL=https://jira.yourcompany.com
JIRA_DC_USERNAME=your-username
JIRA_DC_PASSWORD=your-password

# AI Service Configuration (Future)
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4

# Cache Configuration (Future)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
ENCRYPTION_KEY=your-encryption-key-32-characters